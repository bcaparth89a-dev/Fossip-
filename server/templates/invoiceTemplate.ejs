<!DOCTYPE html>
<html>
  <head>
    <title>Invoice</title>
    <style>
      body { font-family: Arial; }
      table, th, td { border: 1px solid black; border-collapse: collapse; }
      th, td { padding: 8px; }
    </style>
  </head>
  <body>
    <h2>Invoice for <%= invoice.name %></h2>
    <p>Email: <%= invoice.email %></p>
    <p>Phone: <%= invoice.phonenumber %></p>

    <table>
      <thead>
        <tr>
          <th>Product Code</th>
          <th>Name</th>
          <th>Qty</th>
          <th>MRP</th>
          <th>Amount</th>
        </tr>
      </thead>
      <tbody>
        <% invoice.productsDetails.forEach(product => { %>
          <tr>
            <td><%= product.productCode %></td>
            <td><%= product.name %></td>
            <td><%= product.quantity %></td>
            <td><%= product.perproductprice %></td>
            <td><%= product.Price %></td>
          </tr>
        <% }); %>
      </tbody>
    </table>

    <p>Subtotal: <%= invoice.subtotal %></p>
    <p>Discount: <%= invoice.discount %></p>
    <p>Total: <%= invoice.total %></p>
  </body>
</html>
